# Скопируй в файл .env и подставь реальные значения. Файл .env в Git не коммитить.

PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME
JWT_SECRET=случайная_длинная_строка

# URL фронта (CORS, ссылки в письмах)
FRONTEND_URL=http://localhost:5173
# Дополнительные origin через запятую (опционально)
# CORS_EXTRA_ORIGINS=

# Облако для картинок (один из вариантов)
# CLOUDINARY_URL=cloudinary://...
# или отдельно:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Почта: SMTP или Resend (см. backend/utils/email.js)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# RESEND_API_KEY=
# RESEND_FROM=

# Версия оферты (опционально)
# TERMS_VERSION=1.0.0

# Лимиты (опционально)
# RATE_LIMIT_DISABLED=0
# RATE_LIMIT_REGISTER_PER_HOUR=15
# RATE_LIMIT_LOGIN_PER_15MIN=30
# RATE_LIMIT_RESEND_PER_15MIN=10
# EMAIL_RESEND_COOLDOWN_MINUTES=5

# Антиспам: загрузка треков (POST /api/tracks)
# RATE_LIMIT_TRACK_UPLOAD_IP_PER_HOUR=30
# RATE_LIMIT_TRACK_UPLOAD_USER_PER_DAY=15

# Антиспам: смена обложки (PUT/POST .../tracks/:id/cover)
# RATE_LIMIT_COVER_IP_PER_HOUR=60
# RATE_LIMIT_COVER_USER_PER_DAY=40
